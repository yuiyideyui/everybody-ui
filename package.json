{
  "name": "everybody-ui-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages",
    "docs",
    "playground"
  ],
  "scripts": {
    "build": "turbo build",
    "docs:dev": "turbo dev --filter everybody-ui-docs",
    "docs:build": "turbo build --filter everybody-ui-docs",
    "docs:preview": "turbo preview --filter everybody-ui-docs",
    "ui:build": "turbo build --filter everybody-ui"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitejs/plugin-vue-jsx": "^5.1.4",
    "less": "^4.5.1",
    "postcss": "^8.5.6",
    "postcss-prefix-selector": "^2.1.1",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^7.1.5",
    "vite-plugin-dts": "^4.5.4",
    "vitepress": "^2.0.0-alpha.16"
  },
  "dependencies": {
    "vue": "^3.5.29"
  },
  "packageManager": "pnpm@10.0.0"
}
